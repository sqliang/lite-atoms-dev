# Supabase (use a dedicated development project)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# OpenAI-compatible model used by Deep Agents
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
MODEL_NAME=gpt-4.1-mini

# Local platform configuration
PLATFORM_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:8000
PREVIEW_ORIGIN=http://localhost:8081
PROJECTS_ROOT=/var/lib/lite-atoms/projects
ARTIFACTS_ROOT=/var/lib/lite-atoms/artifacts
BUILD_RUNNER_IMAGE=lite-atoms-build-runner:local
PREVIEW_TICKET_SECRET=change-me-to-a-long-random-secret

# Browser configuration (Compose injects these into the frontend build)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:8000
